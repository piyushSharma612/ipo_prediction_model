# Copy this file to .env and fill in your keys.
# Get a free Groq API key at https://console.groq.com (60 sec signup).

GROQ_API_KEY=

# NewsAPI is no longer used (replaced with GDELT 2.0 / Google News RSS in v5).
# Leave blank.
NEWS_API_KEY=

# FRED API key — free at https://fred.stlouisfed.org/docs/api/api_key.html
# When set, enables the Macro Context (FRED) panel: CBOE VIX, US 10Y yield,
# INR/USD, Brent crude, DXY. When blank, the macro panel shows a friendly
# "Set FRED_API_KEY to enable" message and the macro weight (8%) of the
# composite score is redistributed to market_mood.
FRED_API_KEY=

# Paths (relative to project root). Override only if you move things.
FEATURE_STORE_PATH=storage/features/ipo_features.parquet
IPO_MASTER_PATH=data/ipo_master_enriched.csv

# Set to 1 to force the API into mock mode for UI demos without keys.
DEMO_MODE=0

# v5: Google Cloud BigQuery is no longer required. The GDELT 1.0 dependency
# was removed and historical news now comes from Google News RSS (auth-free).
# GOOGLE_APPLICATION_CREDENTIALS=
